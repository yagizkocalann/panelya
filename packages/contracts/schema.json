{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://panelya.local/contracts/v1/schema.json",
  "title": "Panelya Public API Contracts",
  "description": "Language-neutral schemas shared by the Panelya web and Flutter clients.",
  "$defs": {
    "SchemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "PanelTone": {
      "type": "string",
      "enum": ["coral", "mint", "violet", "blue", "amber", "rose"]
    },
    "PublicMediaVariant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["src", "width", "height", "mimeType"],
      "properties": {
        "src": {
          "type": "string",
          "minLength": 1,
          "description": "Public media URL for an available derivative; clients must not construct storage keys."
        },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "mimeType": { "type": "string", "const": "image/webp" }
      }
    },
    "StoryPanelImage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["src", "alt", "width", "height"],
      "properties": {
        "src": { "type": "string", "minLength": 1 },
        "alt": { "type": "string", "minLength": 1 },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "variants": {
          "type": "array",
          "description": "Ready responsive derivatives sorted by ascending width. The source URL remains the fallback.",
          "items": { "$ref": "#/$defs/PublicMediaVariant" }
        }
      }
    },
    "StoryPanel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "scene", "tone"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "scene": { "type": "string", "minLength": 1 },
        "caption": { "type": "string" },
        "dialogue": { "type": "string" },
        "tone": { "$ref": "#/$defs/PanelTone" },
        "align": { "type": "string", "enum": ["left", "right"] },
        "image": { "$ref": "#/$defs/StoryPanelImage" }
      }
    },
    "Episode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "number", "title", "publishedAt", "readTime", "panels"],
      "properties": {
        "slug": { "type": "string", "minLength": 1 },
        "number": { "type": "integer", "minimum": 0 },
        "title": { "type": "string", "minLength": 1 },
        "publishedAt": {
          "type": "string",
          "minLength": 1,
          "description": "Current v1 API returns a localized display label, not an ISO timestamp."
        },
        "readTime": { "type": "string", "minLength": 1 },
        "panels": {
          "type": "array",
          "items": { "$ref": "#/$defs/StoryPanel" }
        }
      }
    },
    "EpisodeSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "number", "title", "publishedAt", "readTime", "panelCount"],
      "properties": {
        "slug": { "type": "string", "minLength": 1 },
        "number": { "type": "integer", "minimum": 0 },
        "title": { "type": "string", "minLength": 1 },
        "publishedAt": { "type": "string", "minLength": 1 },
        "readTime": { "type": "string", "minLength": 1 },
        "panelCount": { "type": "integer", "minimum": 0 }
      }
    },
    "EpisodeNavigationRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "number"],
      "properties": {
        "slug": { "type": "string", "minLength": 1 },
        "number": { "type": "integer", "minimum": 0 }
      }
    },
    "SeriesMetadataFields": {
      "type": "object",
      "required": [
        "slug",
        "title",
        "eyebrow",
        "creator",
        "description",
        "longDescription",
        "status",
        "genres",
        "tone",
        "updatedAt",
        "rating",
        "followers"
      ],
      "properties": {
        "slug": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "eyebrow": { "type": "string", "minLength": 1 },
        "creator": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "longDescription": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["Devam Ediyor", "Tamamlandı"] },
        "genres": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "tone": { "$ref": "#/$defs/PanelTone" },
        "updatedAt": {
          "type": "string",
          "minLength": 1,
          "description": "Current v1 API returns a localized display label, not an ISO timestamp."
        },
        "rating": { "type": "number", "minimum": 0, "maximum": 5 },
        "followers": {
          "type": "string",
          "minLength": 1,
          "description": "Current v1 API returns a localized display label."
        },
        "isNew": { "type": "boolean" },
        "coverImage": { "type": "string", "minLength": 1 },
        "coverImageVariants": {
          "type": "array",
          "description": "Ready responsive cover derivatives sorted by ascending width.",
          "items": { "$ref": "#/$defs/PublicMediaVariant" }
        },
        "coverPosition": { "type": "string", "minLength": 1 }
      }
    },
    "SeriesMetadata": {
      "type": "object",
      "allOf": [
        { "$ref": "#/$defs/SeriesMetadataFields" }
      ],
      "unevaluatedProperties": false
    },
    "SeriesSummary": {
      "type": "object",
      "allOf": [
        { "$ref": "#/$defs/SeriesMetadataFields" },
        {
          "type": "object",
          "required": ["episodeCount", "latestEpisode"],
          "properties": {
            "episodeCount": { "type": "integer", "minimum": 0 },
            "latestEpisode": {
              "oneOf": [
                { "$ref": "#/$defs/Episode" },
                { "type": "null" }
              ]
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "DiscoverySeriesSummary": {
      "type": "object",
      "allOf": [
        { "$ref": "#/$defs/SeriesMetadataFields" },
        {
          "type": "object",
          "required": ["episodeCount"],
          "properties": {
            "episodeCount": { "type": "integer", "minimum": 0 }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "DiscoveryEpisodeUpdate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["series", "episode"],
      "properties": {
        "series": { "$ref": "#/$defs/DiscoverySeriesSummary" },
        "episode": { "$ref": "#/$defs/EpisodeSummary" }
      }
    },
    "DiscoveryResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "featuredSeries",
        "featuredFirstEpisode",
        "genres",
        "newSeries",
        "latestEpisodes"
      ],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/SchemaVersion" },
        "featuredSeries": {
          "oneOf": [
            { "$ref": "#/$defs/DiscoverySeriesSummary" },
            { "type": "null" }
          ]
        },
        "featuredFirstEpisode": {
          "oneOf": [
            { "$ref": "#/$defs/EpisodeSummary" },
            { "type": "null" }
          ]
        },
        "genres": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "newSeries": {
          "type": "array",
          "maxItems": 100,
          "items": { "$ref": "#/$defs/DiscoverySeriesSummary" }
        },
        "latestEpisodes": {
          "type": "array",
          "maxItems": 100,
          "items": { "$ref": "#/$defs/DiscoveryEpisodeUpdate" }
        }
      }
    },
    "CatalogResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "featuredSlug", "series"],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/SchemaVersion" },
        "featuredSlug": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "series": {
          "type": "array",
          "items": { "$ref": "#/$defs/SeriesSummary" }
        }
      }
    },
    "SeriesDetailResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "series", "episodes"],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/SchemaVersion" },
        "series": { "$ref": "#/$defs/SeriesMetadata" },
        "episodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/EpisodeSummary" }
        }
      }
    },
    "EpisodeManifestSeriesRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "title"],
      "properties": {
        "slug": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 }
      }
    },
    "EpisodeNavigation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["previous", "next"],
      "properties": {
        "previous": {
          "oneOf": [
            { "$ref": "#/$defs/EpisodeNavigationRef" },
            { "type": "null" }
          ]
        },
        "next": {
          "oneOf": [
            { "$ref": "#/$defs/EpisodeNavigationRef" },
            { "type": "null" }
          ]
        }
      }
    },
    "EpisodeManifestResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "series", "episode", "navigation"],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/SchemaVersion" },
        "series": { "$ref": "#/$defs/EpisodeManifestSeriesRef" },
        "episode": { "$ref": "#/$defs/Episode" },
        "navigation": { "$ref": "#/$defs/EpisodeNavigation" }
      }
    },
    "AuthProviderConfigResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "provider",
        "flow",
        "issuer",
        "clientId",
        "audience",
        "scopes",
        "authorizationEndpoint",
        "tokenEndpoint",
        "revocationEndpoint",
        "accessTokenLifetimeSeconds",
        "refreshTokenRotation"
      ],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/SchemaVersion" },
        "provider": { "type": "string", "const": "auth0" },
        "flow": { "type": "string", "const": "authorization_code_pkce" },
        "issuer": { "type": "string", "minLength": 1 },
        "clientId": {
          "type": "string",
          "minLength": 1,
          "description": "Public native-application client identifier; never a client secret."
        },
        "audience": { "type": "string", "minLength": 1 },
        "scopes": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "authorizationEndpoint": { "type": "string", "minLength": 1 },
        "tokenEndpoint": { "type": "string", "minLength": 1 },
        "revocationEndpoint": { "type": "string", "minLength": 1 },
        "accessTokenLifetimeSeconds": { "type": "integer", "minimum": 300, "maximum": 3600 },
        "refreshTokenRotation": { "type": "boolean", "const": true }
      }
    },
    "AuthUser": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "displayName", "email", "emailVerified", "role"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Panelya user identifier. Provider subject identifiers are not exposed."
        },
        "displayName": { "type": "string", "minLength": 1 },
        "email": { "type": "string", "minLength": 3 },
        "emailVerified": { "type": "boolean" },
        "role": { "type": "string", "enum": ["reader", "admin"] },
        "avatarUrl": { "type": "string", "minLength": 1 }
      }
    },
    "AuthStateResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "authenticated", "user"],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/SchemaVersion" },
        "authenticated": { "type": "boolean" },
        "user": {
          "oneOf": [
            { "$ref": "#/$defs/AuthUser" },
            { "type": "null" }
          ]
        }
      },
      "if": { "properties": { "authenticated": { "const": true } } },
      "then": { "properties": { "user": { "$ref": "#/$defs/AuthUser" } } },
      "else": { "properties": { "user": { "type": "null" } } }
    },
    "AuthAuthorizationCodeExchangeRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["grantType", "authorizationCode", "codeVerifier", "redirectUri"],
      "properties": {
        "grantType": { "type": "string", "const": "authorization_code" },
        "authorizationCode": { "type": "string", "minLength": 16 },
        "codeVerifier": { "type": "string", "minLength": 43, "maxLength": 128 },
        "redirectUri": { "type": "string", "minLength": 1 }
      }
    },
    "AuthRefreshTokenRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["grantType", "refreshToken"],
      "properties": {
        "grantType": { "type": "string", "const": "refresh_token" },
        "refreshToken": { "type": "string", "minLength": 16 }
      }
    },
    "AuthTokenResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "tokenType",
        "accessToken",
        "expiresIn",
        "refreshToken",
        "scope",
        "user"
      ],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/SchemaVersion" },
        "tokenType": { "type": "string", "const": "Bearer" },
        "accessToken": { "type": "string", "minLength": 16 },
        "expiresIn": { "type": "integer", "minimum": 1, "maximum": 3600 },
        "refreshToken": {
          "type": "string",
          "minLength": 16,
          "description": "Rotating token. The client replaces the previous value atomically after every refresh."
        },
        "scope": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "user": { "$ref": "#/$defs/AuthUser" }
      }
    },
    "AuthRevokeRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["refreshToken"],
      "properties": {
        "refreshToken": { "type": "string", "minLength": 16 }
      }
    },
    "AuthLogoutResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "revoked"],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/SchemaVersion" },
        "revoked": { "type": "boolean", "const": true }
      }
    },
    "AuthErrorResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "error", "reauthenticate"],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/SchemaVersion" },
        "error": {
          "type": "string",
          "enum": [
            "user_cancelled",
            "invalid_grant",
            "login_required",
            "token_expired",
            "token_reused",
            "insufficient_scope",
            "session_revoked",
            "rate_limited",
            "service_unavailable"
          ]
        },
        "errorDescription": { "type": "string", "minLength": 1, "maxLength": 240 },
        "reauthenticate": { "type": "boolean" },
        "retryAfterSeconds": { "type": "integer", "minimum": 1, "maximum": 86400 }
      }
    },
    "ErrorResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["error"],
      "properties": {
        "error": {
          "type": "string",
          "enum": ["series_not_found", "episode_not_found"]
        }
      }
    }
  }
}
