<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12 (API 31)+ SplashScreen API: sistem, uygulama sureci
     baslar baslamaz `windowSplashScreenBackground` +
     `windowSplashScreenAnimatedIcon` degerlerini kullanarak yerel splash
     ekranini cizer (ek bir kutuphane/paket gerektirmez -- bu attribute'lar
     dogrudan mevcut temaya eklenir). Foreground katmani, adaptive icon ile
     ayni mint isaret dosyasini (@mipmap/ic_launcher_foreground) yeniden
     kullanir; boylece ayri bir splash-ozel gorsel uretilmez. -->
<resources>
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@color/brand_background</item>
        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@color/brand_background</item>
    </style>
</resources>
